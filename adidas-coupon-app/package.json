{
  "name": "adidas-coupon-manager",
  "version": "2.4.0",
  "description": "아디다스 쿠폰 발급 관리 프로그램",
  "main": "main.js",
  "author": "Shoepalace",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.shoepalace.adidas-coupon-manager",
    "productName": "아디다스 쿠폰 관리자",
    "win": {
      "target": "dir"
    },
    "files": [
      "**/*",
      "!scripts/__pycache__/**",
      "!scripts/_backup*/**",
      "!*.db",
      "!*.log",
      "!*.xlsx",
      "!temp/**",
      "!dist2/**",
      "!python/**",
      "!nul"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "proxy_list.txt",
        "to": "proxy_list.txt"
      },
      {
        "from": "setup_python.bat",
        "to": "setup_python.bat"
      }
    ],
    "asar": false
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "ws": "^8.14.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
